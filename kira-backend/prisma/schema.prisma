generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URLs are configured via prisma.config.ts in Prisma 7+
  // See prisma.config.ts and set DATABASE_URL in .env for tooling/runtime.
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String?
  pin             String?  // 6-digit PIN (bcrypt hashed)
  google_id       String?  @unique
  profile_picture String?
  phone           String?
  department      String?
  role            String   @default("member") // 'admin', 'member', 'teknisi'

  // Teknisi-specific fields (only populated when role = 'teknisi')
  specialization   String?
  teknisi_status   String?  // 'Tersedia', 'Ditugaskan', 'Tidak Aktif'
  experience_years Int?     @default(0)

  id_perusahaan   String?
  company         Company?         @relation("UserDirectCompany", fields: [id_perusahaan], references: [id])

  ownedCompanies  Company[]
  memberships     CompanyMember[]
  maintenances    Maintenance[]    // sebagai pembuat / id_user
  createdLogs     MaintenanceLog[] @relation("MaintenanceLogCreator")

  // Relations when acting as teknisi
  teknisiMaintenances          Maintenance[]    @relation("MaintenanceTechnician")
  teknisiAssignedMaintenances  Maintenance[]    @relation("AssignedTechnician")
  teknisiLogs                  MaintenanceLog[] @relation("MaintenanceLogTechnician")

  // Ticket relations
  reportedTickets Ticket[] @relation("TicketReporter")
  assignedTickets Ticket[] @relation("TicketAssigned")

  @@map("users")
}

model Company {
  id             String          @id @default(uuid())
  company_name   String
  license_status String
  owner_id       String

  owner       User            @relation(fields: [owner_id], references: [id])
  members     CompanyMember[]
  assets      Asset[]
  gedung      Gedung[]
  tickets     Ticket[]
  direktUsers User[]          @relation("UserDirectCompany")

  @@map("companies")
}

model CompanyMember {
  id_user       String
  id_perusahaan String
  role          String
  joined_at     DateTime @default(now())

  user    User    @relation(fields: [id_user], references: [id])
  company Company @relation(fields: [id_perusahaan], references: [id])

  @@id([id_user, id_perusahaan])
  @@map("company_members")
}

model Gedung {
  id            String @id @default(uuid())
  id_perusahaan String
  nama          String // e.g., 'Gedung A'
  kode          String // e.g., 'A', 'PARKIR', 'UTAMA'

  company Company @relation(fields: [id_perusahaan], references: [id])
  assets  Asset[]

  @@unique([id_perusahaan, kode])
  @@map("gedung")
}

model Asset {
  id                  String   @id @default(uuid())
  id_perusahaan       String
  gedung_id           String?
  asset_name          String
  purchase_date       DateTime
  initial_useful_life Int
  criticality_level   String
  status              String
  asset_image         String?

  merk_id         String?
  kategori_id     String?
  sub_kategori_id String?
  tipe_id         String?

  company            Company                  @relation(fields: [id_perusahaan], references: [id])
  gedung             Gedung?                  @relation(fields: [gedung_id], references: [id])
  merk               Merk?                    @relation(fields: [merk_id], references: [id])
  kategori           Kategori?                @relation(fields: [kategori_id], references: [id])
  subKategori        SubKategori?             @relation(fields: [sub_kategori_id], references: [id])
  tipe               Tipe?                    @relation(fields: [tipe_id], references: [id])
  maintenances       Maintenance[]
  prediction_history AssetPredictionHistory[]
  tickets            Ticket[]

  @@map("assets")
}

model Merk {
  id     String  @id @default(uuid())
  kode   String  @unique
  nama   String
  assets Asset[]

  @@map("merk")
}

model Kategori {
  id     String  @id @default(uuid())
  kode   String  @unique
  nama   String
  assets Asset[]

  @@map("kategori")
}

model SubKategori {
  id     String  @id @default(uuid())
  kode   String  @unique
  nama   String
  assets Asset[]

  @@map("sub_kategori")
}

model Tipe {
  id     String  @id @default(uuid())
  kode   String  @unique
  nama   String
  assets Asset[]

  @@map("tipe")
}

model Maintenance {
  id                     String   @id @default(uuid())
  id_asset               String
  id_user                String
  id_teknisi             String?  // FK ke users (role='teknisi') — teknisi yang ditugaskan
  assigned_technician_id String?  // FK ke users (role='teknisi') — teknisi pelaksana terbaru dari log
  maintenance_type       String
  severity               String   // Low, Medium, High, Critical
  down_time              Int      @default(0)
  cost                   Float    @default(0.0)
  jenis_kerusakan        String?
  penyebab               String?
  spare_part_digunakan   String?
  created_at             DateTime @default(now())

  asset              Asset                    @relation(fields: [id_asset], references: [id])
  user               User                     @relation(fields: [id_user], references: [id])
  assignedTechnician User?                    @relation("AssignedTechnician", fields: [assigned_technician_id], references: [id])
  teknisi            User?                    @relation("MaintenanceTechnician", fields: [id_teknisi], references: [id])
  logs               MaintenanceLog[]
  prediction_history AssetPredictionHistory[]
  ticket             Ticket?

  @@map("maintenances")
}

model MaintenanceLog {
  id             String   @id @default(uuid())
  id_maintenance String
  id_user        String
  technician_id  String?  // FK ke users (role='teknisi')
  status         String
  note           String
  down_time      Int      @default(0)
  cost           Float    @default(0.0)
  created_at     DateTime @default(now())

  maintenance Maintenance @relation(fields: [id_maintenance], references: [id])
  user        User        @relation("MaintenanceLogCreator", fields: [id_user], references: [id])
  teknisi     User?       @relation("MaintenanceLogTechnician", fields: [technician_id], references: [id])

  @@map("maintenance_logs")
}

model Ticket {
  id            String    @id @default(uuid())
  id_perusahaan String
  id_asset      String
  id_reporter   String    // FK ke users (pembuat ticket)
  id_assigned   String?   // FK ke users (role='teknisi', yang ditugaskan)

  title         String
  description   String
  priority      String    @default("Medium") // 'Low', 'Medium', 'High', 'Critical'
  status        String    @default("Open")   // 'Open', 'In Progress', 'Resolved', 'Closed'

  maintenance_id String?  @unique  // FK ke maintenances (jika maintenance dibuat dari ticket)
  resolved_at   DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  company     Company      @relation(fields: [id_perusahaan], references: [id])
  asset       Asset        @relation(fields: [id_asset], references: [id])
  reporter    User         @relation("TicketReporter", fields: [id_reporter], references: [id])
  assigned    User?        @relation("TicketAssigned", fields: [id_assigned], references: [id])
  maintenance Maintenance? @relation(fields: [maintenance_id], references: [id])

  @@map("tickets")
}

model AssetPredictionHistory {
  id             String @id @default(uuid())
  id_asset       String
  id_maintenance String? // NULL jika inisialisasi awal aset baru

  maintenance_count      Int    @default(0)
  average_down_time      Float  @default(0.0)
  total_maintenance_cost Float  @default(0.0)
  max_maintenance_cost   Float  @default(0.0)
  mode_severity          String @default("")

  predicted_rul Int
  recorded_at   DateTime @default(now())

  asset       Asset        @relation(fields: [id_asset], references: [id])
  maintenance Maintenance? @relation(fields: [id_maintenance], references: [id])

  @@map("asset_prediction_history")
}
